        "PENDING",
        "APPROVED",
        "DENIED",
        "PARTIALLY_APPROVED",
        "PENDING_ADDITIONAL_INFO"
      ],
      "example": "APPROVED"
    },
    "certificationNumber": {
      "type": "string",
      "example": "AUTH-2025-001234"
    },
    "effectiveDate": {
      "type": "date",
      "example": "2025-04-01"
    },
    "expirationDate": {
      "type": "date",
      "example": "2025-10-01"
    }
  },
  "name": "ServiceReviewResponse"
}