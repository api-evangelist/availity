{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Dependent",
  "title": "Dependent",
  "type": "object",
  "properties": {
    "firstName": {
      "type": "string"
    },
    "lastName": {
      "type": "string"
    },
    "dateOfBirth": {
      "type": "string",
      "format": "date"
    },
    "gender": {
      "type": "string",
      "enum": [
        "M",
        "F",
        "U"
      ]
    },
    "relationship": {
      "type": "string",
      "enum": [
        1,
        19,
        20,
        21,
        39,
        40,
        "G8"
      ]
    }
  }
}