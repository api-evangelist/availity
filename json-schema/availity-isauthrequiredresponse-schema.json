{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/IsAuthRequiredResponse",
  "title": "IsAuthRequiredResponse",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "example": "500123"
    },
    "authRequired": {
      "type": "string",
      "enum": [
        "Auth Required",
        "No Auth Required"
      ],
      "example": "Auth Required"
    },
    "payerMessage": {
      "type": "string",
      "example": "Prior authorization required for this procedure"
    }
  }
}