{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Subscriber",
  "title": "Subscriber",
  "type": "object",
  "required": [
    "memberId"
  ],
  "properties": {
    "memberId": {
      "type": "string",
      "description": "Insurance member ID"
    },
    "firstName": {
      "type": "string"
    },
    "lastName": {
      "type": "string"
    },
    "dateOfBirth": {
      "type": "string",
      "format": "date"
    },
    "gender": {
      "type": "string",
      "enum": [
        "M",
        "F",
        "U"
      ]
    },
    "ssn": {
      "type": "string",
      "description": "Social Security Number (last 4 or full)"
    },
    "groupNumber": {
      "type": "string"
    }
  }
}